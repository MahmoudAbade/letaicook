rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    function signedIn() {
      return request.auth != null;
    }

    function userData() {
      return get(/databases/$(database)/documents/users/$(request.auth.uid)).data;
    }

    function isAdmin() {
      return signedIn()
        && exists(/databases/$(database)/documents/users/$(request.auth.uid))
        && userData().role == 'admin';
    }

    // Profiles: `users/{uid}` — see apps/web/src/lib/user-model.ts
    match /users/{uid} {
      allow read: if signedIn()
        && (request.auth.uid == uid || isAdmin());
      allow create: if signedIn()
        && request.auth.uid == uid
        && (request.resource.data.role == 'worker' || request.resource.data.role == 'admin');
      allow update: if isAdmin()
        || (request.auth.uid == uid);
      allow delete: if false;
    }

    // AI System Designer workspace: `users/{uid}/systemDesigns/{docId}` — see system-design-model.ts
    match /users/{uid}/systemDesigns/{docId} {
      allow read, write: if signedIn() && request.auth.uid == uid;
    }

    // Planning assistant chat: `users/{uid}/planningChat/{docId}` — see planning-chat-model.ts
    match /users/{uid}/planningChat/{docId} {
      allow read, write: if signedIn() && request.auth.uid == uid;
    }

    // Tasks: `projects/{projectId}/tasks/{taskId}` — see task-model.ts
    match /projects/{projectId}/tasks/{taskId} {
      allow read: if signedIn()
        && (isAdmin() || resource.data.assigneeUid == request.auth.uid);
      allow create: if signedIn() && isAdmin();
      allow update: if signedIn()
        && (isAdmin() || resource.data.assigneeUid == request.auth.uid);
      allow delete: if signedIn() && isAdmin();
    }
  }
}
