# Copy to apps/api/.env.local for local runs, or pass via Docker / deployment secrets.
# Never commit real keys.

# From https://aistudio.google.com/ → Get API key (Google AI Studio / Gemini API)
GOOGLE_API_KEY=

# Optional alias — if set, used when GOOGLE_API_KEY is empty
# GEMINI_API_KEY=

# Model for /chat/plan. Default: gemini-2.5-flash-lite (avoid deprecated gemini-2.0-flash — often quota 0 on free tier).
# GEMINI_MODEL=gemini-2.5-flash-lite

# Comma-separated fallbacks if the primary hits 429 / quota (defaults built into the API if unset).
# GEMINI_MODEL_FALLBACKS=gemini-2.5-flash,gemini-3.1-flash-lite
#
# Same key + model settings power /chat/plan and /design-project (system designer JSON, Jira markdown, pitch).

# Comma-separated browser origins for CORS (Next.js dev server by default).
# CORS_ORIGINS=http://localhost:3000
